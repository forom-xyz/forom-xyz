# ==========================================
# Forom Edge Node Configuration (Jetson/Host)
# ==========================================

# Core Application Settings
VITE_APP_ENV=production
# Update path if the backend proxy runs locally on Jetson
VITE_API_BASE_URL=https://api.forom.etsmtl.ca/v1

# AI & ROM System Settings
VITE_ROM_RAG_ENDPOINT=http://localhost:8000/api/rag
VITE_ROM_MODEL_TIMEOUT=30000

# Authentication (OAuth2/JWT)
VITE_AUTH_DOMAIN=auth.cedille.club
VITE_AUTH_CLIENT_ID=your_client_id_here
VITE_AUTH_CALLBACK_URL=https://forom.prodv2.cedille.club/callback

# Feature Flags
VITE_ENABLE_PHASE_3=false
VITE_DEBUG_MODE=false